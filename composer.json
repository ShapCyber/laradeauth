{
    "name": "laradeauth/laradeauth",
    "description": "Reusable Laravel authentication flow contracts and support classes.",
    "version": "0.1.0",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Ade Owolabi",
			"email": "adego247@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Laradeauth\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laradeauth\\LaradeauthServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/auth": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/validation": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Laradeauth\\Tests\\": "tests/"
        }
    }
}
